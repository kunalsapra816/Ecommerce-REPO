@model List<MiniEcommerMVC.Models.Domain.Product>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">📦 Manage Products</h2>

        <a asp-action="Create" class="btn btn-dark">
            + Add Product
        </a>
    </div>

    <div class="row g-4">

        @foreach (var product in Model)
        {
            @await Html.PartialAsync("~/Views/Shared/_ProductCard.cshtml", product, new ViewDataDictionary(ViewData)
            {
                ["IsAdmin"] = true
            })
        }

    </div>

</div>