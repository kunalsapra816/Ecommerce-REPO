@model MiniEcommerMVC.Models.Domain.Product

@{
    var isAdmin = ViewBag.IsAdmin as bool? ?? false;
}

<div class="col-md-4 col-lg-3">

    <div class="card product-card h-100 border-0">

        <div class="product-img-wrapper">
            <img src="@(string.IsNullOrEmpty(Model.ImageUrl)
                                         ? "/images/default-product.png"
                                         : Model.ImageUrl)"
                 class="card-img-top"
                 alt="@Model.Name"
                 onerror="this.onerror=null;this.src='/images/ECOM.png';" />
        </div>

        <div class="card-body d-flex flex-column">

            <h6 class="product-title">@Model.Name</h6>

            <p class="product-desc">
                @(Model.Description?.Length > 60
                    ? Model.Description.Substring(0, 60) + "..."
                    : Model.Description)
            </p>

            <div class="mt-auto">

                <div class="product-price mb-2">
                    ₹@Model.Price
                </div>

                @if (isAdmin)
                {
                    <!-- 🔴 ADMIN ACTIONS -->
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id"
                               class="btn btn-outline-dark btn-sm w-50">
                            Edit
                        </a>

                        <a asp-action="Delete" asp-route-id="@Model.Id"
                               class="btn btn-outline-danger btn-sm w-50">
                            Delete
                        </a>
                    </div>
                }
                else
                {
                    <!-- 🟢 CUSTOMER ACTION -->
                    @if (Model.StockQuantity > 0)
                    {
                        <button class="btn btn-dark btn-sm w-100 add-to-cart-btn"
                                data-product-id="@Model.Id">
                            🛒 Add to Cart
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-secondary btn-sm w-100" disabled>
                            Out of Stock
                        </button>
                    }
                }

            </div>

        </div>
    </div>

</div>