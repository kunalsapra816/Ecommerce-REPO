@model List<MiniEcommerMVC.Models.Domain.Product>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Explore Products</h2>
        <span class="text-muted">@Model.Count items</span>
    </div>

    <div class="row g-4">
       

            @foreach (var product in Model)
            {
                @await Html.PartialAsync("_ProductCard", product, new ViewDataDictionary(ViewData)
                {
                    ["IsAdmin"] = false
                })
            }

       
</div>